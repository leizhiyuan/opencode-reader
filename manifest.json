{
  "manifest_version": 3,
  "name": "OpenCode Reader",
  "description": "Read articles with AI: select words to explain, ask questions in side panel, powered by local OpenCode server",
  "version": "2.0",
  "permissions": ["contextMenus", "sidePanel", "activeTab", "scripting", "tabs", "storage"],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
